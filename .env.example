# === Bot Mode ===
SIMULATION=true
PAPER_TRADE=false

# === Engine Config ===
ENGINE_MODE=dual
SAFE_CAPITAL=5
MIXED_CAPITAL=5

# === APIs ===
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
POLYGON_RPC=https://polygon-rpc.com
SIGNATURE_TYPE=2

# === Market Filtering ===
MARKETS=btc,eth,sol,xrp
ALL_MARKETS=true

# === Dump & Hedge (Safe Arb) ===
DUMP_HEDGE_SHARES=10
DUMP_HEDGE_SHARES_MAX=100
DUMP_HEDGE_CAPITAL_FRACTION=0.8
DUMP_HEDGE_SUM_TARGET=0.95
DUMP_HEDGE_MOVE_THRESHOLD=0.10
DUMP_HEDGE_STOP_LOSS_MAX_WAIT_MINUTES=2
DUMP_HEDGE_STOP_LOSS_PERCENTAGE=0.2

# === Scalping ===
SCALP_PROFIT_TARGET=3.0
SCALP_HEDGE_TIMEOUT_MS=30000

# === Kelly Sizing ===
KELLY_FRACTION=0.73
MAX_CONSECUTIVE_LOSSES=3
LOSS_REDUCER_MULTIPLIER=0.5

# === Telegram ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Withdrawal ===
WITHDRAWAL_ENABLED=false
WITHDRAWAL_MIN_BALANCE=50
WITHDRAWAL_MAX_DAILY=5000
CHANGENOW_API_KEY=
UPI_IDS=person1@upi,person2@upi

# === KuCoin P2P ===
KUCOIN_API_KEY=
KUCOIN_API_SECRET=

# === Logging ===
LOG_LEVEL=info
